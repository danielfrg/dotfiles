[user]
	name = Daniel Rodriguez
	email = df.rodriguez143@gmail.com
	signingkey = 8D222CABC39ED32B

[push]
	default = simple

[core]
	excludesfile = /Users/danielfrg/.gitignore_global
	quotepath = false

[alias]
    commiti = commit --interactive
    diff = diff --color-words
    st = status
	br = branch
	ci = commit
    co = checkout
    gr = grep -i --color -n -E
	rebase = rebase -i
    logl = log --pretty=oneline --abbrev-commit
    lg = log --graph --topo-order --use-mailmap --stat --decorate
	prune = fetch --prune
	undo = reset --soft HEAD^
	stash-all = stash save --include-untracked
	glog = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
[commit]
	gpgsign = true
