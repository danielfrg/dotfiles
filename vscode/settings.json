// Place your settings in this file to overwrite the default settings
{
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "breadcrumbs.enabled": false,
    "editor.formatOnSave": true,
    "editor.cursorStyle": "line-thin",
    "editor.foldingHighlight": false,
    "editor.fontFamily": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 15,
    "editor.hideCursorInOverviewRuler": true,
    "editor.minimap.showSlider": "always",
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.padding.bottom": 10,
    "editor.padding.top": 10,
    "editor.parameterHints.enabled": false,
    "editor.renderIndentGuides": false,
    "editor.renderLineHighlight": "gutter",
    "editor.renderWhitespace": "none",
    "editor.roundedSelection": false,
    "editor.rulers": [
        80
    ],
    "editor.scrollBeyondLastLine": false,
    "explorer.openEditors.visible": 0,
    "extensions.ignoreRecommendations": true,
    "files.autoSave": "onFocusChange",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "git.autofetch": true,
    "python.dataScience.sendSelectionToInteractiveWindow": true,
    "python.dataScience.useNotebookEditor": false,
    "python.formatting.provider": "black",
    "prettier.requireConfig": true,
    "scm.diffDecorationsGutterWidth": 2,
    "terminal.integrated.fontFamily": "JetBrains Mono, DejaVu Sans Mono for Powerline",
    "terminal.integrated.inheritEnv": false,
    "timeline.excludeSources": [],
    "search.exclude": {
        // Run command (cmd+shift+P) "clear editor history" after changing this
        "**/.git": true,
        "**/node_modules": true,
        "**/*.egg-info": true,
        "**/.pytest_cache": true,
    },
    "vim.disableAnnoyingNeovimMessage": true,
    "vim.insertModeKeyBindings": [
        {
            "after": [
                "<Esc>"
            ],
            "before": [
                "j",
                "k"
            ]
        }
    ],
    "vim.otherModesKeyBindingsNonRecursive": [
        {
            "after": [],
            "before": [
                ";"
            ],
            "commands": [
                {
                    "args": [],
                    "command": "workbench.action.showCommands"
                }
            ]
        }
    ],
    "window.nativeTabs": true,
    "window.zoomLevel": 0,
    "workbench.activityBar.visible": true,
    "workbench.colorCustomizations": {
        "statusBar.foreground": "#24292e",
        "editor.background": "#FAFAFA",
        "editor.foreground": "#323334",
        "sideBar.background": "#F0F0F0",
        "sideBar.foreground": "#323334",
        "terminal.ansiBlack": "#1D2021",
        "terminal.ansiBlue": "#0D6678",
        "terminal.ansiBrightBlack": "#665C54",
        "terminal.ansiBrightBlue": "#0D6678",
        "terminal.ansiBrightCyan": "#8BA59B",
        "terminal.ansiBrightGreen": "#95C085",
        "terminal.ansiBrightMagenta": "#8F4673",
        "terminal.ansiBrightRed": "#FB543F",
        "terminal.ansiBrightWhite": "#FDF4C1",
        "terminal.ansiBrightYellow": "#FAC03B",
        "terminal.ansiCyan": "#8BA59B",
        "terminal.ansiGreen": "#95C085",
        "terminal.ansiMagenta": "#8F4673",
        "terminal.ansiRed": "#FB543F",
        "terminal.ansiWhite": "#A89984",
        "terminal.ansiYellow": "#FAC03B",
        "terminal.background": "#1D2021",
        "terminal.foreground": "#e4e4e4",
        "terminalCursor.background": "#A89984",
        "terminalCursor.foreground": "#A89984"
    },
    "workbench.colorTheme": "GitHub Plus",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.fontAliasing": "antialiased",
    "workbench.iconTheme": "vs-minimal",
    "workbench.startupEditor": "none",
    "workbench.tree.indent": 22,
    "zenMode.hideTabs": false,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "liveSassCompile.settings.formats": [
        // This is the default
        // {
        //     "format": "expanded",
        //     "extensionName": ".css",
        //     "savePath": null
        // },
        // Compressed
        {
            "extensionName": ".min.css",
            "format": "compressed"
        }
    ],
    "liveSassCompile.settings.generateMap": false,
    "python.dataScience.interactiveWindowMode": "perFile",
    "diffEditor.ignoreTrimWhitespace": false,
}
