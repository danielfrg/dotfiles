// Place your settings in this file to overwrite the default settings
{
    "explorer.openEditors.visible": 0,
    "editor.disableTranslate3d": true,
    "window.zoomLevel": 0,
    "go.lintOnSave": true,
    "go.vetOnSave": true,
    "go.formatOnSave": true,
    "go.formatTool": "goimports",
    "go.gopath": "~/workspace/go",
    "go.toolsGopath": "~/workspace/go-tools",
    "go.inferGopath": true,
    "go.autocompleteUnimportedPackages": true,
    "python.venvPath": "~/anaconda/envs",
    "python.formatting.provider": "yapf",
    "workbench.sideBar.location": "left",
    "editor.fontSize": 15,
    "editor.fontFamily": "DejaVu Sans Mono for Powerline, Hack, Menlo, Monaco, 'Courier New', monospace",
    "files.autoSave": "onFocusChange",
    "files.insertFinalNewline": true,
    "vim.easymotion": true,
    "vim.useSolidBlockCursor": true,
    "vim.incsearch": true,
    "vim.overrideCopy": false,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.handleKeys": {
        "<C-d>": true
    },
    "vim.insertModeKeyBindings": [
        {
            "before": ["j","k"],
            "after": ["<Esc>"]
        }
    ],
    "vim.otherModesKeyBindingsNonRecursive": [
        {
            "before": [";"],
            "after": [],
            "commands": [
                {
                    "command": "workbench.action.showCommands",
                    "args": []
                }
            ]
        }
    ],
    "vim.disableAnnoyingNeovimMessage": true,
    "liveSassCompile.settings.formats":[
        // This is Default.
        // {
        //     "format": "expanded",
        //     "extensionName": ".css",
        //     "savePath": null
        // },
        // Minimilized
        {
            "format": "compressed",
            "extensionName": ".min.css"
        }
    ],
    "workbench.iconTheme": "material-icon-theme",
    "workbench.colorTheme": "Nord Wave",
    "git.autofetch": false,
    "liveSassCompile.settings.generateMap": false,
    "workbench.statusBar.feedback.visible": false,
    "editor.minimap.enabled": false,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "terminal.external.osxExec": "iTerm2.app",
    "python.dataScience.sendSelectionToInteractiveWindow": true,
    "breadcrumbs.enabled": false
}
